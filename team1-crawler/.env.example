# ── Database ─────────────────────────────────────────────────────────────────
# Dari Supabase dashboard → Project Settings → Database → Connection string (URI)
# Pastikan pakai mode "Transaction" atau "Session" (port 5432)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── Supabase Storage ──────────────────────────────────────────────────────────
# Dari Supabase dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Nama bucket di Supabase Storage (buat manual di dashboard sekali saja)
# Dashboard → Storage → New bucket → nama: "datalake", set Public: false
SUPABASE_BUCKET=datalake

# ── Platform APIs ─────────────────────────────────────────────────────────────

# Apify: WAJIB untuk crawler TikTok & YouTube Shorts
# Dapatkan token dari https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_...

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
LOG_LEVEL=INFO
APP_PORT=8000
TIMEZONE=Asia/Jakarta

# ── Proxy (optional) ──────────────────────────────────────────────────────────
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
